# GTM Outreach Agent — local config (NEVER commit this with real values).
# `apply init` writes most of these for you. Edit by hand if you prefer.

# --- Required -----------------------------------------------------------

# Anthropic API key. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Google Sheet ID. Create a blank Sheet, copy the ID from its URL:
#   https://docs.google.com/spreadsheets/d/<ID>/edit
# Leave empty to skip Sheet integration (Gmail drafts only).
SHEET_ID=

# --- Sender details -----------------------------------------------------

# Your email (the From: address on staged Gmail drafts).
SENDER_EMAIL=
# Your name. Sign-off comes from Profile/voice_config.yaml::signature, not this field.
SENDER_NAME=

# --- Optional -----------------------------------------------------------

# Slack incoming webhook for Step 7 notifications. Leave empty to skip.
SLACK_WEBHOOK_URL=

# Apollo (deferred — Step 7 alternative to Clay/Claude.ai for contact discovery).
USE_APOLLO=false
APOLLO_API_KEY=

# --- Defaults you usually don't need to change --------------------------

# Models. Sonnet for drafting, Haiku for parsing.
CLAUDE_DRAFT_MODEL=claude-sonnet-4-6
CLAUDE_PARSE_MODEL=claude-haiku-4-5-20251001

# Google OAuth paths (created by `apply init`).
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
GOOGLE_TOKEN_PATH=credentials/token.json

# Google Sheet tab name.
SHEET_TAB_NAME=Outreach

# Profile pack directory.
PROFILE_DIR=Profile

# Resume PDF path (used as an attachment on Gmail drafts).
RESUME_PATH=Profile/resume.pdf

# Send schedule (Step 7).
DEFAULT_TIMEZONE=America/New_York
SEND_DAYS=Tue,Wed,Thu
SEND_WINDOW=07:00-09:00
SEND_JITTER_MINUTES=5-15
FOLLOWUP_1_DAYS=4
FOLLOWUP_2_DAYS=9

# Logging.
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
